# MotoBaku Academy - Apache/Namecheap shared hosting rules

DirectoryIndex index.html index.php
ErrorDocument 404 /404.html
Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Canonical production host: https://motobakuacademy.az
  # Scoped to the real domain so local XAMPP paths are not redirected.
  RewriteCond %{HTTP_HOST} ^www\.motobakuacademy\.az$ [NC,OR]
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP_HOST} ^(www\.)?motobakuacademy\.az$ [NC]
  RewriteRule ^ https://motobakuacademy.az%{REQUEST_URI} [R=301,L]

  # Make the admin directory URL resolve even when directory indexes are disabled.
  RewriteRule ^admin/?$ /admin/index.php [L]

  # Never expose repository or environment internals.
  RewriteRule (^|/)\.git - [F,L]
  RewriteRule (^|/)\.env(\..*)?$ - [F,L]

  # Uploaded media should never execute as scripts.
  RewriteRule ^admin/storage/.*\.(php|phtml|phar|cgi|pl|asp|aspx|jsp)$ - [F,L,NC]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  <FilesMatch "\.(html?)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  <FilesMatch "\.(avif|webp|png|jpe?g|gif|svg|ico|woff2?|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

AddType image/webp .webp
AddType application/manifest+json .webmanifest

<FilesMatch "^(\.env|AGENTS\.md)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
